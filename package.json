{
  "name": "music-player",
  "description": "A full-featured music player desktop app built with Vue 3 and Electron",
  "author": "Music Player Dev",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.music-player.app",
    "productName": "Music Player",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*.cjs"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/favicon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Music Player"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vue-tsc && vite build",
    "build:electron": "vite build && electron-builder",
    "preview": "vite preview",
    "electron:start": "electron ."
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^14.3.0",
    "animate.css": "^4.1.1",
    "axios": "^1.18.1",
    "element-plus": "^2.14.2",
    "howler": "^2.2.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.24",
    "@iconify/vue": "^5.0.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/howler": "^2.2.13",
    "@types/mockjs": "^1.0.10",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "gsap": "^3.15.0",
    "mockjs": "^1.1.0",
    "motion-vue": "^0.0.1",
    "postcss": "^8.5.16",
    "sass": "^1.101.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vue-tsc": "^3.3.6",
    "wait-on": "^9.0.10"
  }
}
